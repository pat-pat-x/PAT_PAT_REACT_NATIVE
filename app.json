{
  "expo": {
    "name": "PAT PAT",
    "slug": "pat-pat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "com.patpat.app",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#070f24"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.patpat.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "일기를 안전하게 보호하기 위해 Face ID를 사용합니다.",
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#070f24"
      },
      "package": "com.patpat.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#070f24"
        }
      ],
      "expo-local-authentication"
    ]
  }
}
